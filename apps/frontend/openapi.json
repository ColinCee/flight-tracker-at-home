{
  "openapi": "3.1.0",
  "info": {
    "title": "Flight Tracker at Home API",
    "version": "0.1.0"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health Check",
        "description": "Simple health check.",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/aircraft": {
      "get": {
        "summary": "Get Aircraft State",
        "description": "Main polling endpoint.\nFetches the lazy-cached state, abstracting the OpenSky API rate limits.",
        "operationId": "getAircraft",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AircraftResponse"
                }
              }
            }
          }
        }
      }
    },
    "/debug/opensky": {
      "get": {
        "summary": "OpenSky Connectivity Test",
        "description": "Diagnose OpenSky API connectivity from this server.",
        "operationId": "debugOpensky",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/weather": {
      "get": {
        "summary": "Get London Airport Weather",
        "description": "Fetches METAR weather for London airports.\nCached for 30 minutes to respect upstream rate limits.",
        "operationId": "getWeather",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WeatherResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AircraftResponse": {
        "properties": {
          "timestamp": {
            "type": "integer",
            "title": "Timestamp"
          },
          "cacheAgeSeconds": {
            "type": "number",
            "title": "Cacheageseconds"
          },
          "refreshIntervalMs": {
            "type": "integer",
            "title": "Refreshintervalms"
          },
          "aircraft": {
            "items": {
              "$ref": "#/components/schemas/AircraftState"
            },
            "type": "array",
            "title": "Aircraft"
          },
          "kpis": {
            "$ref": "#/components/schemas/KPIs"
          }
        },
        "type": "object",
        "required": [
          "timestamp",
          "cacheAgeSeconds",
          "refreshIntervalMs",
          "aircraft",
          "kpis"
        ],
        "title": "AircraftResponse",
        "description": "Single response for the main polling endpoint."
      },
      "AircraftState": {
        "properties": {
          "icao24": {
            "type": "string",
            "title": "Icao24"
          },
          "callsign": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Callsign"
          },
          "originCountry": {
            "type": "string",
            "title": "Origincountry"
          },
          "latitude": {
            "type": "number",
            "title": "Latitude"
          },
          "longitude": {
            "type": "number",
            "title": "Longitude"
          },
          "baroAltitude": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Baroaltitude"
          },
          "geoAltitude": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Geoaltitude"
          },
          "velocity": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Velocity"
          },
          "trueTrack": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Truetrack"
          },
          "verticalRate": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Verticalrate"
          },
          "onGround": {
            "type": "boolean",
            "title": "Onground"
          },
          "squawk": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Squawk"
          },
          "lastContact": {
            "type": "integer",
            "title": "Lastcontact"
          },
          "positionSource": {
            "type": "string",
            "title": "Positionsource"
          },
          "category": {
            "type": "string",
            "title": "Category"
          },
          "isApproachingLhr": {
            "type": "boolean",
            "title": "Isapproachinglhr"
          }
        },
        "type": "object",
        "required": [
          "icao24",
          "callsign",
          "originCountry",
          "latitude",
          "longitude",
          "baroAltitude",
          "geoAltitude",
          "velocity",
          "trueTrack",
          "verticalRate",
          "onGround",
          "squawk",
          "lastContact",
          "positionSource",
          "category",
          "isApproachingLhr"
        ],
        "title": "AircraftState",
        "description": "One aircraft's state, transformed from OpenSky's positional array."
      },
      "AirportWeather": {
        "properties": {
          "icao": {
            "type": "string",
            "title": "Icao"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "condition": {
            "type": "string",
            "title": "Condition"
          },
          "temperatureC": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Temperaturec"
          },
          "windSpeedKts": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Windspeedkts"
          },
          "windDirectionDeg": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Winddirectiondeg"
          }
        },
        "type": "object",
        "required": [
          "icao",
          "name",
          "condition",
          "temperatureC",
          "windSpeedKts",
          "windDirectionDeg"
        ],
        "title": "AirportWeather",
        "description": "Weather data for a specific airport via MET Norway."
      },
      "KPIs": {
        "properties": {
          "trackedAircraft": {
            "type": "integer",
            "title": "Trackedaircraft"
          },
          "airborneAircraft": {
            "type": "integer",
            "title": "Airborneaircraft"
          },
          "inboundLhrAircraft": {
            "type": "integer",
            "title": "Inboundlhraircraft"
          },
          "climbingAircraft": {
            "type": "integer",
            "title": "Climbingaircraft"
          },
          "descendingAircraft": {
            "type": "integer",
            "title": "Descendingaircraft"
          },
          "throughputLast60Min": {
            "type": "integer",
            "title": "Throughputlast60Min"
          },
          "avgAltitudeFt": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Avgaltitudeft"
          },
          "apiHealth": {
            "type": "string",
            "enum": [
              "live",
              "stale",
              "offline"
            ],
            "title": "Apihealth"
          },
          "apiCreditsRemaining": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Apicreditsremaining"
          }
        },
        "type": "object",
        "required": [
          "trackedAircraft",
          "airborneAircraft",
          "inboundLhrAircraft",
          "climbingAircraft",
          "descendingAircraft",
          "throughputLast60Min",
          "avgAltitudeFt",
          "apiHealth",
          "apiCreditsRemaining"
        ],
        "title": "KPIs"
      },
      "WeatherResponse": {
        "properties": {
          "timestamp": {
            "type": "integer",
            "title": "Timestamp"
          },
          "cacheAgeSeconds": {
            "type": "number",
            "title": "Cacheageseconds"
          },
          "weather": {
            "items": {
              "$ref": "#/components/schemas/AirportWeather"
            },
            "type": "array",
            "title": "Weather"
          }
        },
        "type": "object",
        "required": [
          "timestamp",
          "cacheAgeSeconds",
          "weather"
        ],
        "title": "WeatherResponse",
        "description": "Single response for the weather polling endpoint."
      }
    }
  }
}
