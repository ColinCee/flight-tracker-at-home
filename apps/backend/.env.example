# --- Proxy mode (production) ---
# When set, all OpenSky requests go through the Cloudflare Worker proxy
# which handles OAuth2 auth and avoids hyperscaler IP blocking.
# OPENSKY_PROXY_URL=https://opensky-proxy.<account>.workers.dev
# OPENSKY_PROXY_KEY=<shared-secret>

# --- Direct mode (local dev, no proxy) ---
# OpenSky Network OAuth2 credentials (https://opensky-network.org)
# Create an API client at: Account → API Clients → Create
# Authenticated: 4000+ API credits/day + 5s resolution
# Anonymous (no credentials): 400 credits/day + 10s resolution
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Cache TTL in seconds (production: 20, dev default: 5s auth / 10s anon)
# Credit-aware throttling scales this up automatically when credits are low.
# CACHE_TTL=20
